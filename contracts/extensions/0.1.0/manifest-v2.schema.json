{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pi-rust.local/contracts/extensions/manifest-v2.schema.json",
  "title": "Pi Extension Manifest v2 Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "api",
    "component",
    "lock",
    "activation",
    "permissions",
    "contributions",
    "limits"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$",
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "api": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires"],
      "properties": {
        "requires": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "world"],
      "properties": {
        "path": { "const": "component.wasm" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "world": { "const": "pi:extension/extension@0.1.0" }
      }
    },
    "lock": { "const": "extension.lock.json" },
    "dependencies": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "requires"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "requires": { "type": "string", "minLength": 1, "maxLength": 128 },
          "optional": { "type": "boolean", "default": false }
        }
      }
    },
    "activation": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "enum": ["workspace", "session", "explicit"] }
    },
    "permissions": {
      "type": "array",
      "maxItems": 128,
      "uniqueItems": true,
      "items": {
        "enum": [
          "model.invoke",
          "process.exec",
          "ui.interact",
          "workspace.read",
          "workspace.write"
        ]
      }
    },
    "contributions": {
      "$ref": "contributions-v1.schema.json"
    },
    "resources": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^resources/[A-Za-z0-9._/-]+$" }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memoryBytes", "fuel", "deadlineMs", "outputBytes"],
      "properties": {
        "memoryBytes": { "type": "integer", "minimum": 65536, "maximum": 268435456 },
        "fuel": { "type": "integer", "minimum": 1, "maximum": 1000000000 },
        "deadlineMs": { "type": "integer", "minimum": 1, "maximum": 300000 },
        "outputBytes": { "type": "integer", "minimum": 1, "maximum": 16777216 }
      }
    }
  }
}
