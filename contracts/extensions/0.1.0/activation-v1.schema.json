{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pi-rust.local/contracts/extensions/activation-v1.schema.json",
  "title": "Pi Workspace Extension Activation v1 Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workspaceId", "roots", "packages", "grants"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "workspaceId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "roots": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
    },
    "packages": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "grant-v1.schema.json#/$defs/identity" }
    },
    "grants": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "grant-v1.schema.json" }
    }
  }
}
