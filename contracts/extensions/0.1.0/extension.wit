package pi:extension@0.1.0;

interface types {
  record registration {
    kind: string,
    id: string,
    schema-revision: u32,
    definition: list<u8>,
  }

  record invocation {
    operation-id: string,
    handler-id: string,
    input-schema-revision: u32,
    input: list<u8>,
  }

  record invocation-output {
    output-schema-revision: u32,
    output: list<u8>,
  }

  variant extension-error {
    invalid-input(string),
    denied(string),
    cancelled,
    deadline-exceeded,
    output-limit,
    internal(string),
  }
}

interface host-diagnostics {
  enum level {
    info,
    warning,
    error,
  }

  emit: func(level: level, code: string, message: string) -> result<_, string>;
}

interface host-workspace {
  use types.{extension-error};

  read-text: func(relative-path: string) -> result<string, extension-error>;
  write-text: func(relative-path: string, text: string) -> result<_, extension-error>;
}

interface host-model {
  use types.{extension-error};

  invoke: func(prompt: string) -> result<string, extension-error>;
}

interface host-process {
  use types.{extension-error};

  record output {
    status: s32,
    stdout: string,
    stderr: string,
  }

  exec: func(program: string, arguments: list<string>) -> result<output, extension-error>;
}

interface host-ui {
  use types.{extension-error};

  interact: func(action-id: string, input: list<u8>) -> result<list<u8>, extension-error>;
}

interface guest {
  use types.{registration, invocation, invocation-output, extension-error};

  activate: func() -> result<list<registration>, extension-error>;
  invoke: func(request: invocation) -> result<invocation-output, extension-error>;
}

world extension {
  import host-diagnostics;
  import host-workspace;
  import host-model;
  import host-process;
  import host-ui;
  export guest;
}
